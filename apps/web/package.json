{
  "name": "@totp-webapp/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm install --prefix ../../packages/shared && npm run build --prefix ../../packages/shared && npm install --prefix ../../packages/crypto && npm run build --prefix ../../packages/crypto",
    "build": "tsc -p tsconfig.json && vite build",
    "build:extension": "npm run prebuild && tsc -p tsconfig.json && vite build --mode extension",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/extension-layout-smoke.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@totp-webapp/crypto": "file:../../packages/crypto",
    "@totp-webapp/shared": "file:../../packages/shared",
    "@vitejs/plugin-react": "^4.3.4",
    "html5-qrcode": "^2.3.8",
    "idb": "^8.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.0.7"
  }
}
